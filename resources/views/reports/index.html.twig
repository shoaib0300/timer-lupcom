{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('reports.title') }}{% endblock %}
{% set active_nav = 'reports' %}

{% block content %}
<div class="reports-page">
<h1 class="page-title">{{ trans('reports.title') }}</h1>

<div class="card reports-filters">
    <form method="get" action="/reports" class="reports-filters__form" id="reports-filter-form">
        <input type="hidden" name="month" value="{{ month }}">
        {% if selected_day %}
            <input type="hidden" name="day" value="{{ selected_day }}">
        {% endif %}

        <div class="reports-filters__row">
            <div class="form-group">
                <label for="filter-project">{{ trans('common.project') }}</label>
                <select id="filter-project" name="project_id">
                    <option value="">{{ trans('common.all_projects') }}</option>
                    {% for project in projects %}
                        <option value="{{ project.id }}"{% if project_id == project.id %} selected{% endif %}>
                            {{ project.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label for="filter-task">{{ trans('common.task') }}</label>
                <select id="filter-task" name="task_id"{% if project_id is empty %} disabled{% endif %}>
                    <option value="">{{ trans('common.all_tasks') }}</option>
                    {% for task in tasks %}
                        <option value="{{ task.id }}"{% if task_id == task.id %} selected{% endif %}>
                            {{ task.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group reports-filters__actions">
                <label>&nbsp;</label>
                <button type="submit" class="btn btn--primary">{{ trans('common.apply_filters') }}</button>
            </div>
        </div>
    </form>
</div>

<section class="card calendar-card">
    <div class="calendar-header">
        <div class="calendar-header__nav">
            <a href="/reports?{{ prev_month_query }}" class="btn btn--ghost btn--sm" aria-label="{{ trans('common.previous_month') }}">&larr;</a>
            <h2 class="calendar-header__title">{{ month_label }}</h2>
            <a href="/reports?{{ next_month_query }}" class="btn btn--ghost btn--sm" aria-label="{{ trans('common.next_month') }}">&rarr;</a>
        </div>
        <p class="muted calendar-header__total">{{ trans('common.month_total', {total: month_total})|raw }}</p>
    </div>

    <div class="calendar-grid" role="grid" aria-label="{{ trans('reports.calendar_label') }}">
        <div class="calendar-grid__weekdays" aria-hidden="true">
            <span>{{ trans('reports.weekday.mon') }}</span>
            <span>{{ trans('reports.weekday.tue') }}</span>
            <span>{{ trans('reports.weekday.wed') }}</span>
            <span>{{ trans('reports.weekday.thu') }}</span>
            <span>{{ trans('reports.weekday.fri') }}</span>
            <span>{{ trans('reports.weekday.sat') }}</span>
            <span>{{ trans('reports.weekday.sun') }}</span>
        </div>
        <div class="calendar-grid__days">
            {% for cell in calendar_cells %}
                {% set cell_month = cell.date|slice(0, 7) %}
                {% set day_query = 'month=' ~ cell_month %}
                {% if project_id %}{% set day_query = day_query ~ '&project_id=' ~ project_id %}{% endif %}
                {% if task_id %}{% set day_query = day_query ~ '&task_id=' ~ task_id %}{% endif %}
                {% set day_query = day_query ~ '&day=' ~ cell.date %}
                <a
                    href="/reports?{{ day_query }}"
                    class="calendar-day{% if not cell.in_month %} calendar-day--outside{% endif %}{% if cell.is_today %} calendar-day--today{% endif %}{% if selected_day == cell.date %} calendar-day--selected{% endif %}{% if cell.total_seconds > 0 %} calendar-day--has-time{% endif %}"
                    aria-label="{{ cell.date }}{% if cell.total_seconds > 0 %}, {{ format_time(cell.total_seconds) }}{% endif %}"
                >
                    <span class="calendar-day__number">{{ cell.day }}</span>
                    {% if cell.total_seconds > 0 %}
                        <span class="calendar-day__time">{{ format_time(cell.total_seconds) }}</span>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    </div>
</section>

{% if selected_day %}
    <section class="card reports-page__day-detail">
        <div class="section-header">
            <h2>{{ selected_day_label }}</h2>
            <span class="muted">{{ trans('common.total') }}: <strong>{{ day_total }}</strong></span>
        </div>

        {% if day_entries is empty %}
            <p class="muted">{{ trans('reports.no_time_day') }}</p>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>{{ trans('common.project') }}</th>
                        <th>{{ trans('dashboard.task_reason') }}</th>
                        <th>{{ trans('common.started') }}</th>
                        <th>{{ trans('common.duration') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in day_entries %}
                        <tr>
                            <td>
                                {% if entry.isGeneral %}
                                    <span class="project-dot" style="background: #64748b;"></span>
                                    {{ trans('common.general') }}
                                {% else %}
                                    <span class="project-dot" style="background: {{ entry.projectColor }};"></span>
                                    {{ entry.projectName }}
                                {% endif %}
                            </td>
                            <td>
                                {% if entry.isGeneral %}
                                    {{ entry.notes ?: trans('common.general_time') }}
                                {% else %}
                                    {{ entry.displayLabel() }}
                                {% endif %}
                            </td>
                            <td class="muted">{{ entry.startedAt }}</td>
                            <td>{{ format_time(entry.durationSeconds) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>
{% else %}
    <p class="muted reports-hint">{{ trans('reports.click_day') }}</p>
{% endif %}
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/assets/js/reports.js"></script>
{% endblock %}
