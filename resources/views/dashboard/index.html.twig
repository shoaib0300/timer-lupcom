{% extends 'layouts/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% set active_nav = 'dashboard' %}

{% block content %}
<h1 class="page-title">Dashboard</h1>

<div class="grid grid--2">
    <div class="card">
        <div class="muted">Tracked today</div>
        <div class="stat">{{ total_today }}</div>
    </div>
    <div class="card">
        <div class="muted">Projects</div>
        <div class="stat">{{ projects|length }}</div>
    </div>
</div>

<section class="card" style="margin-top: 1.5rem;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <h2 style="margin:0;">Start timer</h2>
        <a href="/projects/create" class="btn btn--ghost btn--sm">New project</a>
    </div>

    {% if projects is empty %}
        <p class="muted">No projects yet. <a href="/projects/create">Create your first project</a>.</p>
    {% else %}
        <div class="grid">
            {% for project in projects %}
                <div class="card" style="background: var(--surface-alt, #334155);">
                    <h3 style="margin-top:0;">
                        <span class="project-dot" style="background: {{ project.color }};"></span>
                        {{ project.name }}
                    </h3>
                    <p class="muted">{{ format_time(project.totalSeconds) }} tracked</p>

                    <div class="actions">
                        <button
                            type="button"
                            class="btn btn--success btn--sm js-start-timer"
                            data-project-id="{{ project.id }}"
                            data-project-name="{{ project.name }}"
                        >
                            Start project
                        </button>
                    </div>

                    {% set project_tasks = tasks_by_project[project.id] ?? [] %}
                    {% if project_tasks is not empty %}
                        <ul style="margin:1rem 0 0; padding-left:1.2rem;">
                            {% for task in project_tasks %}
                                <li style="margin-bottom:0.5rem;">
                                    {{ task.name }}
                                    <span class="muted">({{ format_time(task.totalSeconds) }})</span>
                                    <button
                                        type="button"
                                        class="btn btn--primary btn--sm js-start-timer"
                                        data-project-id="{{ project.id }}"
                                        data-project-name="{{ project.name }}"
                                        data-task-id="{{ task.id }}"
                                        data-task-name="{{ task.name }}"
                                    >
                                        Start
                                    </button>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>

<section class="card" style="margin-top: 1.5rem;">
    <h2>Recent sessions</h2>
    {% if recent_entries is empty %}
        <p class="muted">No time entries yet.</p>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Task</th>
                    <th>Duration</th>
                    <th>Ended</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in recent_entries %}
                    <tr>
                        <td>
                            <span class="project-dot" style="background: {{ entry.projectColor }};"></span>
                            {{ entry.projectName }}
                        </td>
                        <td>{{ entry.taskName ?? '—' }}</td>
                        <td>{{ format_time(entry.durationSeconds) }}</td>
                        <td class="muted">{{ entry.endedAt }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</section>
{% endblock %}

{% block scripts %}
<script>
    window.__TIMER_INITIAL__ = {{ timer|json_encode|raw }};
</script>
{% endblock %}
