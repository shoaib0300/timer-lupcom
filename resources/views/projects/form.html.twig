{% extends 'layouts/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% set active_nav = 'projects' %}

{% block content %}
<h1 class="page-title">{{ title }}</h1>

<div class="card form-card">
    {% if error is defined %}
        <div class="alert alert--error">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ action }}">
        <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="{{ project.name ?? '' }}" required>
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description">{{ project.description ?? '' }}</textarea>
        </div>

        <div class="form-group">
            <label for="color">Color</label>
            <input type="color" id="color" name="color" value="{{ project.color ?? '#3b82f6' }}">
        </div>

        <div class="actions">
            <button type="submit" class="btn btn--primary">Save</button>
            <a href="{% if project %}/projects/{{ project.id }}{% else %}/projects{% endif %}" class="btn btn--ghost">Cancel</a>
        </div>
    </form>

    {% if project %}
        <div class="danger-zone">
            <h2>Delete project</h2>
            <p class="muted">Removes all tasks and time entries for this project.</p>
            <form method="post" action="/projects/{{ project.id }}/delete" onsubmit="return confirm('Delete project &quot;{{ project.name|e('js') }}&quot;? This cannot be undone.');">
                <button type="submit" class="btn btn--danger btn--sm">Delete project</button>
            </form>
        </div>
    {% endif %}
</div>
{% endblock %}
