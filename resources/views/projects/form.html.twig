{% extends 'layouts/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% set active_nav = 'projects' %}

{% block content %}
<h1 class="page-title">{{ title }}</h1>

<div class="card form-card">
    {% if error is defined %}
        <div class="alert alert--error">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ action }}">
        <div class="form-group">
            <label for="name">{{ trans('projects.form.name') }}</label>
            <input type="text" id="name" name="name" value="{{ project.name ?? '' }}" required>
        </div>

        <div class="form-group">
            <label for="description">{{ trans('projects.form.description') }}</label>
            <textarea id="description" name="description">{{ project.description ?? '' }}</textarea>
        </div>

        <div class="form-group">
            <label for="color">{{ trans('projects.form.color') }}</label>
            <input type="color" id="color" name="color" value="{{ project.color ?? '#3b82f6' }}">
        </div>

        <div class="actions">
            <button type="submit" class="btn btn--primary">{{ trans('common.save') }}</button>
            <a href="{% if project %}/projects/{{ project.id }}{% else %}/projects{% endif %}" class="btn btn--ghost">{{ trans('common.cancel') }}</a>
        </div>
    </form>

    {% if project %}
        <div class="danger-zone">
            <h2>{{ trans('projects.form.danger_zone') }}</h2>
            <p class="muted">{{ trans('projects.form.delete_note') }}</p>
            <form method="post" action="/projects/{{ project.id }}/delete" onsubmit="return confirm('{{ trans('projects.form.delete_confirm_undo', {name: project.name})|e('js') }}');">
                <button type="submit" class="btn btn--danger btn--sm">{{ trans('dashboard.delete_project') }}</button>
            </form>
        </div>
    {% endif %}
</div>
{% endblock %}
