{% extends 'layouts/base.html.twig' %}

{% block title %}{{ project.name }}{% endblock %}
{% set active_nav = 'projects' %}

{% block content %}
<div class="project-show">
    <div class="page-header project-show__header">
        <div class="project-show__intro">
            <h1 class="page-title">
                <span class="project-dot" style="background: {{ project.color }};"></span>
                {{ project.name }}
            </h1>
            <div class="project-show__meta">
                {% if project.planioId %}
                    <span class="project-show__planio-badge">Planio #{{ project.planioId }}</span>
                {% endif %}
                <span class="muted js-project-total" data-project-id="{{ project.id }}" data-total-seconds="{{ project.totalSeconds }}">{{ trans('projects.tracked', {time: format_time(project.totalSeconds)}) }}</span>
            </div>
            {% if project.description %}
                <p class="project-show__description muted">{{ project.description }}</p>
            {% endif %}
        </div>
        <div class="actions project-show__actions">
            <button
                type="button"
                class="btn btn--success js-start-timer"
                data-project-id="{{ project.id }}"
                data-project-name="{{ project.name }}"
            >
                {{ trans('timer.start_timer') }}
            </button>
            <a href="/projects/{{ project.id }}/edit" class="btn btn--ghost">{{ trans('common.edit') }}</a>
            <a href="/projects/{{ project.id }}/tasks/create" class="btn btn--primary">{{ trans('projects.add_task') }}</a>
            <form class="inline-form" method="post" action="/projects/{{ project.id }}/delete" onsubmit="return confirm('{{ trans('projects.delete_confirm_short')|e('js') }}');">
                <button type="submit" class="btn btn--danger">{{ trans('common.delete') }}</button>
            </form>
        </div>
    </div>

    <div class="card project-show__tasks" id="project-tasks" data-project-id="{{ project.id }}" data-project-name="{{ project.name }}">
        <h2>{{ trans('projects.tasks') }}</h2>
        <div id="project-tasks-content">
            {% if tasks is empty %}
                <p class="muted js-tasks-empty">{{ trans('projects.no_tasks_yet') }}</p>
            {% else %}
                <div class="project-show__table-wrap">
                    <table class="table project-show__table">
                        <thead>
                            <tr>
                                <th>{{ trans('common.name') }}</th>
                                <th class="project-show__col-planio">{{ trans('projects.planio_number') }}</th>
                                <th>{{ trans('common.status') }}</th>
                                <th>{{ trans('common.time') }}</th>
                                <th class="project-show__col-actions">{{ trans('common.actions') }}</th>
                            </tr>
                        </thead>
                        <tbody id="project-tasks-body">
                            {% for task in tasks %}
                                <tr data-task-id="{{ task.id }}">
                                    <td class="project-show__task-name">
                                        {% if task.planioAssignee %}
                                            <span class="project-show__assignee">{{ task.planioAssignee }}</span>
                                            <span class="project-show__assignee-sep muted" aria-hidden="true">·</span>
                                        {% endif %}
                                        <span class="project-show__task-title">{{ task.name }}</span>
                                    </td>
                                    <td class="project-show__col-planio">
                                        {% if task.planioIssueId %}
                                            <span class="project-show__planio-badge project-show__planio-badge--sm">#{{ task.planioIssueId }}</span>
                                        {% else %}
                                            <span class="muted">{{ trans('common.none') }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if task.planioIssueId %}
                                            <span class="badge badge--planio" title="{{ trans('tasks.synced_from_planio') }}">{{ task.status }}</span>
                                        {% else %}
                                            <span class="badge badge--{{ task.status }}">{{ task.status|replace({'_': ' '}) }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ format_time(task.totalSeconds) }}</td>
                                    <td class="project-show__col-actions">
                                        <div class="project-show__row-actions">
                                            <button
                                                type="button"
                                                class="btn btn--primary btn--sm js-start-timer"
                                                data-project-id="{{ project.id }}"
                                                data-project-name="{{ project.name }}"
                                                data-task-name="{{ task.name }}"
                                            >
                                                {{ trans('common.start') }}
                                            </button>
                                            <a href="/tasks/{{ task.id }}/edit" class="btn btn--ghost btn--sm">{{ trans('common.edit') }}</a>
                                            <form class="inline-form" method="post" action="/tasks/{{ task.id }}/delete" onsubmit="return confirm('{{ trans('tasks.delete_confirm')|e('js') }}');">
                                                <button type="submit" class="btn btn--danger btn--sm">{{ trans('common.delete') }}</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
