{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('nav.planio') }}{% endblock %}
{% set active_nav = 'planio' %}

{% block content %}
<div class="settings-page">
    <h1 class="page-title">{{ trans('planio.title') }}</h1>

    <div class="settings-page__readonly-banner" role="note">
        <strong>{{ trans('planio.readonly_banner') }}</strong> — {{ trans('planio.readonly_body', {host: 'support.lupcom.de'})|raw }}
    </div>

    {% if flash_success %}
        <div class="alert alert--success">{{ flash_success }}</div>
    {% endif %}
    {% if flash_error %}
        <div class="alert alert--error">{{ flash_error }}</div>
    {% endif %}

    <section class="card settings-page__connection">
        <h2>{{ trans('planio.connection') }}</h2>

        {% if has_api_key %}
            <p class="settings-page__status">
                <span class="settings-page__status-dot" aria-hidden="true"></span>
                {{ trans('planio.api_key_saved') }}
            </p>
        {% endif %}

        <form method="post" action="/settings/planio" class="settings-page__form">
            <div class="settings-page__row">
                <div class="form-group">
                    <label for="planio-base-url">{{ trans('planio.url') }}</label>
                    <input
                        type="url"
                        id="planio-base-url"
                        name="base_url"
                        value="{{ planio.base_url|default('https://support.lupcom.de') }}"
                        placeholder="https://support.lupcom.de"
                        required
                    >
                </div>
                <div class="form-group">
                    <label for="planio-api-key">{{ trans('planio.api_key') }}</label>
                    <input
                        type="password"
                        id="planio-api-key"
                        name="api_key"
                        value=""
                        placeholder="{% if has_api_key %}{{ trans('planio.api_key_placeholder_saved') }}{% else %}{{ trans('planio.api_key_placeholder_new') }}{% endif %}"
                        autocomplete="off"
                        {% if not has_api_key %}required{% endif %}
                    >
                    <p class="muted settings-page__hint">{{ trans('planio.api_key_hint') }}</p>
                </div>
            </div>
            <div class="actions">
                <button type="submit" class="btn btn--primary">{{ trans('planio.save_connection') }}</button>
                {% if has_api_key %}
                    <button type="button" class="btn btn--ghost" id="planio-test-btn">{{ trans('planio.test_connection') }}</button>
                {% endif %}
            </div>
        </form>

        {% if has_api_key %}
            <form method="post" action="/settings/planio/disconnect" class="settings-page__disconnect" onsubmit="return confirm('{{ trans('planio.disconnect_confirm')|e('js') }}');">
                <button type="submit" class="btn btn--ghost btn--sm">{{ trans('planio.disconnect') }}</button>
            </form>
        {% endif %}

        {% if has_api_key and planio.user_name %}
            <div class="settings-page__user card">
                <h3>{{ trans('planio.last_verified') }}</h3>
                <p class="muted settings-page__user-note">{{ trans('planio.last_verified_note') }}</p>
                <dl class="settings-page__user-details">
                    <div><dt>{{ trans('planio.user_name') }}</dt><dd>{{ planio.user_name }}</dd></div>
                    {% if planio.user_login %}<div><dt>{{ trans('planio.user_login') }}</dt><dd>{{ planio.user_login }}</dd></div>{% endif %}
                    {% if planio.user_id %}<div><dt>{{ trans('planio.user_id') }}</dt><dd>{{ planio.user_id }}</dd></div>{% endif %}
                    {% if planio.user_email %}<div><dt>{{ trans('planio.user_email') }}</dt><dd>{{ planio.user_email }}</dd></div>{% endif %}
                    {% if planio.last_sync_at %}<div><dt>{{ trans('planio.last_import') }}</dt><dd>{{ planio.last_sync_at }}</dd></div>{% endif %}
                </dl>
            </div>
        {% endif %}
    </section>

    {% if has_api_key %}
        <section class="card settings-page__import">
            <div class="settings-page__import-header">
                <h2>{{ trans('planio.import_projects') }}</h2>
                <button type="button" class="btn btn--ghost btn--sm" id="planio-load-projects">{{ trans('planio.load_projects') }}</button>
            </div>
            <p class="muted">{{ trans('planio.import_intro') }}</p>

            <div class="settings-page__filters">
                <div class="form-group">
                    <label for="planio-project-filter">{{ trans('planio.filter') }}</label>
                    <input type="search" id="planio-project-filter" placeholder="{{ trans('planio.filter_placeholder') }}">
                </div>
                <label class="settings-page__checkbox">
                    <input type="checkbox" id="planio-select-visible">
                    {{ trans('planio.select_visible') }}
                </label>
                <label class="settings-page__checkbox">
                    <input type="checkbox" id="planio-import-issues" checked>
                    {{ trans('planio.import_issues') }}
                </label>
            </div>

            <p class="muted is-hidden" id="planio-projects-empty">{{ trans('planio.no_projects_loaded') }}</p>
            <p class="muted is-hidden" id="planio-projects-loading">{{ trans('planio.loading_projects') }}</p>

            <div class="settings-page__project-list is-hidden" id="planio-project-list"></div>

            <div class="actions settings-page__import-actions is-hidden" id="planio-import-actions">
                <button type="button" class="btn btn--primary" id="planio-sync-btn">{{ trans('planio.import_selected') }}</button>
                <span class="muted" id="planio-selected-count">{{ trans('planio.selected_count', {count: 0}) }}</span>
            </div>

            <div class="settings-page__import-progress is-hidden" id="planio-import-progress" role="status" aria-live="polite">
                <div class="settings-page__progress-header">
                    <span id="planio-import-progress-label">{{ trans('planio.importing') }}</span>
                    <span class="settings-page__progress-pct" id="planio-import-progress-pct">0%</span>
                </div>
                <div class="settings-page__progress-track">
                    <div class="settings-page__progress-bar" id="planio-import-progress-bar"></div>
                </div>
                <p class="muted settings-page__progress-detail" id="planio-import-progress-detail"></p>
            </div>

            <p class="settings-page__feedback is-hidden" id="planio-sync-feedback" role="status"></p>
        </section>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/assets/js/planio-settings.js"></script>
{% endblock %}
