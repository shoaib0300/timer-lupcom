<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Timer{% endblock %} | Lupcom Timer</title>
    <link rel="stylesheet" href="/assets/css/main.css">
    {% block head %}{% endblock %}
</head>
<body>
    <div class="app-shell">
        <aside class="timer-sidebar" id="timer-sidebar">
            <div class="timer-sidebar__header">
                <h2 class="timer-sidebar__title">Active timers</h2>
                <span class="timer-sidebar__count" id="timer-count">0</span>
            </div>
            <div class="timer-sidebar__list" id="timer-list"></div>
            <p class="timer-sidebar__empty muted" id="timer-empty">No active timers</p>
        </aside>

        <div class="app-main">
            <header class="site-header">
                <div class="site-header__inner">
                    <a href="/" class="brand">Lupcom Timer</a>
                    <nav class="nav">
                        <a href="/" class="{% if active_nav == 'dashboard' %}is-active{% endif %}">Dashboard</a>
                        <a href="/reports" class="{% if active_nav == 'reports' %}is-active{% endif %}">Time log</a>
                        <a href="/projects" class="{% if active_nav == 'projects' %}is-active{% endif %}">Projects</a>
                        <a href="/settings/planio" class="{% if active_nav == 'planio' %}is-active{% endif %}">Planio</a>
                    </nav>
                </div>
            </header>

            <main class="container">
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    <div id="timer-modal" class="modal is-hidden" aria-hidden="true">
        <div class="modal__backdrop" data-modal-close></div>
        <div class="modal__dialog" role="dialog" aria-labelledby="timer-modal-title">
            <h3 id="timer-modal-title" class="modal__title">Start timer</h3>
            <p class="muted" id="timer-modal-project"></p>
            <form id="timer-start-form">
                <div class="form-group">
                    <label for="timer-task-select">Task</label>
                    <select id="timer-task-select" name="task_select" required>
                        <option value="">Loading tasks…</option>
                    </select>
                </div>
                <div class="form-group is-hidden" id="timer-new-task-group">
                    <label for="timer-task-name">New task name</label>
                    <input type="text" id="timer-task-name" name="task_name" placeholder="Enter task name" autocomplete="off">
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn--success">Start</button>
                    <button type="button" class="btn btn--ghost" data-modal-close>Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script type="module" src="/assets/js/app.js?v=11"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
