<!DOCTYPE html>
<html lang="{{ locale }}" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ trans('app.name') }}{% endblock %} | {{ trans('app.title_suffix') }}</title>
    <script>
    (function () {
        var theme = localStorage.getItem('timer-theme');
        if (theme === 'light' || theme === 'dark') {
            document.documentElement.setAttribute('data-theme', theme);
        }
    })();
    </script>
    <link rel="stylesheet" href="/assets/css/main.css">
    {% block head %}{% endblock %}
</head>
<body>
    <div id="theme-transition" class="theme-transition" aria-hidden="true" hidden></div>
    <div class="app-shell">
        <aside class="timer-sidebar" id="timer-sidebar">
            <div class="timer-sidebar__header">
                <h2 class="timer-sidebar__title">{{ trans('timer.active_timers') }}</h2>
                <span class="timer-sidebar__count" id="timer-count">0</span>
            </div>
            <div class="timer-sidebar__list" id="timer-list"></div>
            <p class="timer-sidebar__empty muted" id="timer-empty">{{ trans('timer.no_active') }}</p>
        </aside>

        <div class="app-main">
            <header class="site-header">
                <div class="site-header__inner">
                    <a href="/" class="brand">{{ trans('app.name') }}</a>
                    <nav class="nav">
                        <a href="/" class="{% if active_nav == 'dashboard' %}is-active{% endif %}">{{ trans('nav.dashboard') }}</a>
                        <a href="/reports" class="{% if active_nav == 'reports' %}is-active{% endif %}">{{ trans('nav.time_log') }}</a>
                        <a href="/attendance" class="{% if active_nav == 'attendance' %}is-active{% endif %}">{{ trans('nav.attendance') }}</a>
                        <a href="/projects" class="{% if active_nav == 'projects' %}is-active{% endif %}">{{ trans('nav.projects') }}</a>
                        <a href="/settings/planio" class="{% if active_nav == 'planio' %}is-active{% endif %}">{{ trans('nav.planio') }}</a>
                        <button
                            type="button"
                            class="theme-toggle"
                            id="theme-toggle"
                            aria-label="{{ trans('theme.light') }}"
                            title="{{ trans('theme.light') }}"
                        >
                            <svg class="theme-toggle__icon--dark" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M12 17a5 5 0 0 1 0-10 5 5 0 0 1 0 10Zm1-16a1 1 0 0 0-2 0v1.1a1 1 0 1 0 2 0V1Zm0 19a1 1 0 0 0-2 0v1.1a1 1 0 1 0 2 0V20ZM3 11a1 1 0 1 0 0 2h1.1a1 1 0 1 0 0-2H3Zm17.9 0a1 1 0 1 0 0 2H22a1 1 0 1 0 0-2h-1.1ZM5.64 5.64a1 1 0 0 0 0 1.41l.78.78a1 1 0 0 0 1.41-1.41l-.78-.78a1 1 0 0 0-1.41 0Zm12.14 12.14a1 1 0 0 0 0 1.41l.78.78a1 1 0 0 0 1.41-1.41l-.78-.78a1 1 0 0 0-1.41 0ZM5.64 18.36a1 1 0 0 0 1.41 0l.78-.78a1 1 0 0 0-1.41-1.41l-.78.78a1 1 0 0 0 0 1.41Zm12.14-12.14a1 1 0 0 0 1.41 0l.78-.78a1 1 0 0 0-1.41-1.41l-.78.78a1 1 0 0 0 0 1.41Z"/></svg>
                            <svg class="theme-toggle__icon--light" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M12 3a9 9 0 1 0 9 9 7 7 0 0 1-9-9Z"/></svg>
                        </button>
                    </nav>
                </div>
            </header>

            <main class="container">
                {% if not hide_page_back|default(false) %}
                <button
                    type="button"
                    class="page-back"
                    id="page-back"
                    aria-label="{{ trans('common.back') }}"
                    title="{{ trans('common.back') }}"
                    data-fallback="/"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M15.41 16.59 10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
                </button>
                {% endif %}
                {% block content %}{% endblock %}
            </main>
        </div>

        <aside class="quick-sidebar" id="quick-sidebar" aria-label="{{ trans('dashboard.quick_start') }}">
            <section class="quick-sidebar__section task-quick-search">
                <h2 class="quick-sidebar__title">{{ trans('dashboard.quick_start') }}</h2>
                <p class="muted quick-sidebar__intro">{{ trans('dashboard.quick_start_intro') }}</p>
                <div class="task-quick-search__wrap" id="task-quick-search-wrap">
                    <label class="task-quick-search__label" for="task-quick-search-input">{{ trans('dashboard.search_tasks') }}</label>
                    <input
                        type="search"
                        id="task-quick-search-input"
                        class="task-quick-search__input"
                        placeholder="{{ trans('dashboard.search_tasks_placeholder') }}"
                        autocomplete="off"
                        role="combobox"
                        aria-expanded="false"
                        aria-controls="task-quick-search-results"
                        aria-autocomplete="list"
                    >
                    <div id="task-quick-search-results" class="task-quick-search__results" role="listbox" hidden></div>
                    <p class="muted task-quick-search__empty is-hidden" id="task-quick-search-empty">{{ trans('dashboard.no_task_match') }}</p>
                </div>
            </section>

            <section class="quick-sidebar__section quick-sidebar__frequent" id="timer-frequent">
                <h2 class="quick-sidebar__title">{{ trans('timer.frequent_tasks') }}</h2>
                <p class="muted quick-sidebar__empty is-hidden" id="timer-frequent-empty">{{ trans('timer.no_frequent_tasks') }}</p>
                <div class="quick-sidebar__frequent-list" id="timer-frequent-list"></div>
            </section>
        </aside>
    </div>

    <div id="timer-modal" class="modal is-hidden" aria-hidden="true">
        <div class="modal__backdrop" data-modal-close></div>
        <div class="modal__dialog" role="dialog" aria-labelledby="timer-modal-title">
            <h3 id="timer-modal-title" class="modal__title">{{ trans('timer.start_timer') }}</h3>
            <p class="muted" id="timer-modal-project"></p>
            <form id="timer-start-form">
                <div class="form-group">
                    <label for="timer-task-select">{{ trans('common.task') }}</label>
                    <select id="timer-task-select" name="task_select" required>
                        <option value="">{{ trans('timer.loading_tasks') }}</option>
                    </select>
                </div>
                <div class="form-group is-hidden" id="timer-new-task-group">
                    <label for="timer-task-name">{{ trans('timer.new_task_name') }}</label>
                    <input type="text" id="timer-task-name" name="task_name" placeholder="{{ trans('timer.task_placeholder') }}" autocomplete="off">
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn--success">{{ trans('common.start') }}</button>
                    <button type="button" class="btn btn--ghost" data-modal-close>{{ trans('common.cancel') }}</button>
                </div>
            </form>
        </div>
    </div>

    <script>window.__I18N__ = {{ js_translations|json_encode|raw }};</script>
    <script type="module" src="/assets/js/app.js?v=21"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
