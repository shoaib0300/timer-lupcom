{% extends 'layouts/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% set active_nav = 'projects' %}

{% block content %}
<h1 class="page-title">{{ title }}</h1>
<p class="muted">{{ trans('tasks.project_label', {name: project.name}) }}</p>

<div class="card" style="max-width: 560px;">
    {% if error is defined %}
        <div class="alert alert--error">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ action }}">
        <div class="form-group">
            <label for="name">{{ trans('common.name') }}</label>
            <input type="text" id="name" name="name" value="{{ task.name ?? '' }}" required>
        </div>

        <div class="form-group">
            <label for="description">{{ trans('projects.form.description') }}</label>
            <textarea id="description" name="description">{{ task.description ?? '' }}</textarea>
        </div>

        <div class="form-group">
            <label for="status">{{ trans('common.status') }}</label>
            {% if task is defined and task and task.planioIssueId %}
                <p class="task-form__planio-status">
                    <span class="badge badge--planio">{{ task.status }}</span>
                </p>
                <p class="muted task-form__planio-status-note">{{ trans('tasks.planio_status_note') }}</p>
            {% else %}
                <select id="status" name="status">
                    {% set current = task.status ?? 'open' %}
                    <option value="open" {% if current == 'open' %}selected{% endif %}>{{ trans('tasks.status.open') }}</option>
                    <option value="in_progress" {% if current == 'in_progress' %}selected{% endif %}>{{ trans('tasks.status.in_progress') }}</option>
                    <option value="done" {% if current == 'done' %}selected{% endif %}>{{ trans('tasks.status.done') }}</option>
                </select>
            {% endif %}
        </div>

        <div class="actions">
            <button type="submit" class="btn btn--primary">{{ trans('common.save') }}</button>
            <a href="/projects/{{ project.id }}" class="btn btn--ghost">{{ trans('common.cancel') }}</a>
        </div>
    </form>
</div>
{% endblock %}
